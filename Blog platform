const blogDetails = document.getElementById("blogDetails");
const commentBtn = document.getElementById("commentBtn");
const commentInput = document.getElementById("commentInput");
const commentList = document.getElementById("commentList");

const params = new URLSearchParams(window.location.search);
const id = parseInt(params.get("id"));

const blogs = JSON.parse(localStorage.getItem("blogs")) || [];

const blog = blogs[id];

if(blog){

    blogDetails.innerHTML = `
        <div class="blog-detail-card">

            <img src="${blog.image || 'https://picsum.photos/800/400'}">

            <div class="blog-detail-content">

                <h2>${blog.title}</h2>

                <p>${blog.content}</p>

            </div>

        </div>
    `;

}

let comments = JSON.parse(localStorage.getItem("comments")) || [];

function showComments(){

    commentList.innerHTML = "";

    comments
        .filter(comment => comment.blogId == id)
        .forEach(comment => {

            commentList.innerHTML += `
                <div class="comment">
                    ${comment.text}
                </div>
            `;

        });

}

commentBtn.onclick = function(){

    if(commentInput.value.trim() === ""){
        alert("Please enter a comment.");
        return;
    }

    comments.push({

        blogId:id,
        text:commentInput.value

    });

    localStorage.setItem("comments", JSON.stringify(comments));

    commentInput.value = "";

    showComments();

};

showComments();
// Check Login

if(localStorage.getItem("loggedIn") !== "true"){
    window.location.href = "login.html";
}

const showFormBtn = document.getElementById("showFormBtn");
const publishBtn = document.getElementById("publishBtn");
const blogForm = document.getElementById("blogForm");
const myBlogs = document.getElementById("myBlogs");
const logoutBtn = document.getElementById("logoutBtn");

let blogs = JSON.parse(localStorage.getItem("blogs")) || [];

showFormBtn.onclick = function(){
    blogForm.style.display = "block";
};

publishBtn.onclick = function(){

    const title = document.getElementById("title").value;
    const image = document.getElementById("image").value;
    const content = document.getElementById("content").value;

    if(title==="" || content===""){
        alert("Please fill all required fields.");
        return;
    }

    blogs.push({
        title,
        image,
        content
    });

    localStorage.setItem("blogs",JSON.stringify(blogs));

    displayBlogs();

    document.getElementById("title").value="";
    document.getElementById("image").value="";
    document.getElementById("content").value="";
};

function displayBlogs(){

    myBlogs.innerHTML="";

    blogs.forEach((blog,index)=>{

        myBlogs.innerHTML+=`

        <div class="blog-card">

            <img src="${blog.image || 'https://picsum.photos/400/250'}">

            <div class="blog-content">

                <h3>${blog.title}</h3>

                <p>${blog.content.substring(0,100)}...</p>

                <div class="action-buttons">

                    <button class="edit-btn" onclick="editBlog(${index})">
                        Edit
                    </button>

                    <button class="delete-btn" onclick="deleteBlog(${index})">
                        Delete
                    </button>

                </div>

            </div>

        </div>

        `;
    });

}

function deleteBlog(index){

    blogs.splice(index,1);

    localStorage.setItem("blogs",JSON.stringify(blogs));

    displayBlogs();

}

function editBlog(index){

    const blog=blogs[index];

    document.getElementById("title").value=blog.title;
    document.getElementById("image").value=blog.image;
    document.getElementById("content").value=blog.content;

    blogs.splice(index,1);

    localStorage.setItem("blogs",JSON.stringify(blogs));

    displayBlogs();

}

logoutBtn.onclick=function(){

    localStorage.removeItem("loggedIn");

    window.location.href="login.html";

};

displayBlogs();
const loginForm = document.getElementById("loginForm");

loginForm.addEventListener("submit", function (e) {

    e.preventDefault();

    const email = document.getElementById("email").value.trim();
    const password = document.getElementById("password").value;

    if (email === "" || password === "") {
        alert("Please fill all fields.");
        return;
    }

    // Temporary login
    localStorage.setItem("loggedIn", "true");

    alert("Login Successful!");

    window.location.href = "dashboard.html";

});
