/* Reset */
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Arial, Helvetica, sans-serif;
}

body{
    background:#f4f6f9;
    color:#333;
}

/* Navbar */

.navbar{
    background:#2c3e50;
    color:#fff;
    display:flex;
    justify-content:space-between;
    align-items:center;
    padding:18px 60px;
}

.logo{
    font-size:28px;
    font-weight:bold;
}

.nav-links{
    display:flex;
    list-style:none;
}

.nav-links li{
    margin-left:25px;
}

.nav-links a{
    color:white;
    text-decoration:none;
    font-size:17px;
    transition:.3s;
}

.nav-links a:hover{
    color:#f1c40f;
}

/* Hero */

.hero{
    text-align:center;
    padding:80px 20px;
    background:linear-gradient(135deg,#3498db,#6dd5fa);
    color:white;
}

.hero h2{
    font-size:42px;
    margin-bottom:20px;
}

.hero p{
    font-size:18px;
    margin-bottom:30px;
}

.btn{
    display:inline-block;
    background:#2c3e50;
    color:white;
    padding:14px 30px;
    text-decoration:none;
    border-radius:8px;
    font-size:18px;
    transition:.3s;
}

.btn:hover{
    background:#1abc9c;
}

/* Blog Section */

.blogs{
    width:90%;
    margin:50px auto;
}

.blogs h2{
    text-align:center;
    margin-bottom:30px;
    font-size:32px;
}

.blog-container{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(300px,1fr));
    gap:25px;
}

/* Blog Card */

.blog-card{
    background:white;
    border-radius:10px;
    overflow:hidden;
    box-shadow:0 4px 10px rgba(0,0,0,.15);
    transition:.3s;
}

.blog-card:hover{
    transform:translateY(-8px);
}

.blog-card img{
    width:100%;
    height:200px;
    object-fit:cover;
}

.blog-content{
    padding:20px;
}

.blog-content h3{
    margin-bottom:12px;
}

.blog-content p{
    margin-bottom:20px;
    color:#666;
}

.read-btn{
    display:inline-block;
    background:#3498db;
    color:white;
    padding:10px 20px;
    text-decoration:none;
    border-radius:5px;
}

.read-btn:hover{
    background:#2c3e50;
}

/* Responsive */

@media(max-width:768px){

.navbar{
    flex-direction:column;
    padding:20px;
}

.nav-links{
    margin-top:15px;
}

.hero h2{
    font-size:30px;
}

.hero p{
    font-size:16px;
}

}
/* Form Section */

.form-section{
    display:flex;
    justify-content:center;
    align-items:center;
    padding:60px 20px;
}

.form-box{
    width:400px;
    background:#fff;
    padding:30px;
    border-radius:10px;
    box-shadow:0 4px 10px rgba(0,0,0,.15);
}

.form-box h2{
    text-align:center;
    margin-bottom:25px;
}

.form-box input{
    width:100%;
    padding:12px;
    margin-bottom:18px;
    border:1px solid #ccc;
    border-radius:6px;
    font-size:16px;
}

.form-box button{
    width:100%;
    border:none;
    cursor:pointer;
}

.form-link{
    text-align:center;
    margin-top:20px;
}

.form-link a{
    color:#3498db;
    text-decoration:none;
}

.form-link a:hover{
    text-decoration:underline;
}
.dashboard{
    width:90%;
    margin:40px auto;
}

.dashboard h2{
    margin-bottom:20px;
}

.blog-form{
    background:white;
    padding:25px;
    border-radius:10px;
    margin:25px 0;
    box-shadow:0 5px 12px rgba(0,0,0,.15);
}

.blog-form input,
.blog-form textarea{
    width:100%;
    padding:12px;
    margin-bottom:15px;
    border:1px solid #ccc;
    border-radius:6px;
    font-size:16px;
}

.blog-form textarea{
    resize:vertical;
}

.action-buttons{
    display:flex;
    gap:10px;
    margin-top:15px;
}

.edit-btn,
.delete-btn{
    padding:10px 18px;
    border:none;
    border-radius:5px;
    color:white;
    cursor:pointer;
}

.edit-btn{
    background:#3498db;
}

.delete-btn{
    background:#e74c3c;
}

.edit-btn:hover{
    background:#2980b9;
}

.delete-btn:hover{
    background:#c0392b;
}
.blog-page{
    width:90%;
    max-width:900px;
    margin:40px auto;
}

.blog-detail-card{
    background:#fff;
    border-radius:10px;
    overflow:hidden;
    box-shadow:0 4px 10px rgba(0,0,0,.15);
    margin-bottom:30px;
}

.blog-detail-card img{
    width:100%;
    height:350px;
    object-fit:cover;
}

.blog-detail-content{
    padding:25px;
}

.blog-detail-content h2{
    margin-bottom:15px;
}

.blog-detail-content p{
    line-height:1.7;
}

.comment-section{
    background:#fff;
    padding:25px;
    border-radius:10px;
    box-shadow:0 4px 10px rgba(0,0,0,.15);
}

.comment-section textarea{
    width:100%;
    padding:12px;
    margin:15px 0;
    border:1px solid #ccc;
    border-radius:6px;
    resize:vertical;
}

.comment{
    margin-top:15px;
    padding:12px;
    border-left:4px solid #3498db;
    background:#f8f9fa;
    border-radius:5px;
}
